# Render Postgres connection string (set automatically when linking a Postgres DB in Render)
DATABASE_URL=

# Admin panel password (required in production)
ADMIN_PASSWORD=

# GTM and Clarity are loaded from the root layout (GTM-PG85KF4P, Clarity vhqcoclky2).
# Do not set NEXT_PUBLIC_GTM_ID or NEXT_PUBLIC_CLARITY_ID to avoid loading them twice.
